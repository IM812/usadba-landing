# ================================================================
# Усадьба в Антропково — переменные окружения
# Скопируй этот файл в .env.local и заполни значения
# ================================================================

# --- Supabase (база данных) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Авторизация в админку ---
# Логин и пароль для входа в /admin
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your-strong-password

# Секрет для подписи сессионной куки (сгенерируй: openssl rand -base64 32)
SESSION_SECRET=your-random-32-byte-secret

# --- Telegram уведомления (опционально) ---
# Бот токен и chat_id куда слать уведомления о новых бронированиях
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- ICS синхронизация (опционально) ---
# URL от Airbnb / Avito для импорта занятых дат
AVITO_ICS_URL=
